{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeCanvas",
  "version": "0.1.0",
  "identifier": "com.timecanvas.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TimeCanvas",
        "width": 1280,
        "height": 840,
        "minWidth": 720,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/sugi-kzm/timeCanvas/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCRjlEMTEwNTYxMTBDNUQKUldSZERCRldFTkg1T3lwR2w3eXhlRHZSdnk5RkN6UnkzRmdzSytVYVcxbGFzK2k3RG90eCtya20K"
    }
  }
}
